// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model WorkOrder {
  id              String   @id @default(cuid())
  customerName    String?
  customerContact String?
  deviceType      String?
  serialNumber    String?
  condition       String?
  complaint       String?
  status          String   @default("Átvétel alatt") // Statuses in Hungarian
  priority        String   @default("Normál")       // Sürgős, Magas, Normál, Alacsony
  estimatedDone   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  notes           Note[]
  photos          Photo[]
  statusHistory   StatusLog[]
  lineItems       LineItem[]
  archivedPdfPath String?
}

model LineItem {
  id          String    @id @default(cuid())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String
  description String
  amount      Int       @default(0)
  createdAt   DateTime  @default(now())
}

model Settings {
  id             Int     @id @default(1)
  baseUrl        String  @default("http://localhost:3000")
  logoPath       String?
  workshopName   String  @default("Szerviz Központ")
  technicianName String?
}

model StatusLog {
  id          String    @id @default(cuid())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String
  status      String
  createdAt   DateTime  @default(now())
}

model Note {
  id          String    @id @default(cuid())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String
  text        String
  createdAt   DateTime  @default(now())
}

model Photo {
  id          String    @id @default(cuid())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String
  filePath    String
  description String?
  createdAt   DateTime  @default(now())
}

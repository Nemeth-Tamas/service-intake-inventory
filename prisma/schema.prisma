// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model WorkOrder {
  id              String   @id @default(cuid())
  customerName    String?
  customerContact String?
  deviceType      String?
  serialNumber    String?
  condition       String?
  complaint       String?
  accessories     String?
  estimatedPrice  String?
  warranty        String?
  warrantyExpiry  DateTime?
  status          String   @default("Átvétel alatt") // Statuses in Hungarian
  priority        String   @default("Normál")       // Sürgős, Magas, Normál, Alacsony
  estimatedDone   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  notes           Note[]
  photos          Photo[]
  statusHistory   StatusLog[]
  lineItems       LineItem[]
  archivedPdfPath String?
  
  // Signature fields
  isWaitingForSignature Boolean   @default(false)
  signatureData         String?   // Base64 encoded signature image
  signedAt              DateTime?
  signedDeclarationText String?   // Snapshot of the declaration text at the time of signing
}

model LineItem {
  id          String    @id @default(cuid())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String
  description String
  amount      Int       @default(0)
  createdAt   DateTime  @default(now())
}

model Settings {
  id                  Int     @id @default(1)
  baseUrl             String  @default("http://localhost:3000")
  logoPath            String?
  workshopName        String  @default("Szerviz Központ")
  technicianName      String?
  address             String?
  phone               String?
  email               String?
  website             String?
  googleReviewUrl     String?
  declarationTemplate String  @default("Alulírott ügyfél kijelentem, hogy a szolgáltatás megkezdése előtt tájékoztatást kaptam arról, hogy személyes adataimról biztonsági mentést kell készítenem. Az üzlet minden ésszerű lépést megtesz az adatok védelme érdekében, de nem garantálja a teljes körű helyreállítást, és nem vállal felelősséget az adatvesztésért. Hozzájárulok a készülék állapotának fotózásához és a mentett fájlok vírusellenőrzéséhez.")
  representativeSignature String? // Base64 signature of the workshop representative

  // Backup configurations
  backupInterval      String  @default("none") // none, daily, weekly
  lastBackupTime      DateTime?
  backupStatus        String  @default("none") // success, failed, none
  backupError         String?
  nasBackupPath       String?

  // Email SMTP settings
  smtpHost            String?
  smtpPort            Int?
  smtpUser            String?
  smtpPass            String?
  smtpFrom            String?

  // SMS Gateway settings
  smsApiUrl           String?
  smsApiKey           String?
  smsSender           String?
}

model StatusLog {
  id          String    @id @default(cuid())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String
  status      String
  createdAt   DateTime  @default(now())
}

model Note {
  id          String    @id @default(cuid())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String
  text        String
  createdAt   DateTime  @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  type        String   // INFO, WARNING, SUCCESS, SYSTEM
  message     String
  entityId    String?  // Optional reference to a WorkOrder ID
  createdAt   DateTime @default(now())
}

model Photo {
  id          String    @id @default(cuid())
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String
  filePath    String
  description String?
  createdAt   DateTime  @default(now())
}
